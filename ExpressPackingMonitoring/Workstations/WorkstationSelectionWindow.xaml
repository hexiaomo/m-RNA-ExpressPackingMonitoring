<Window x:Class="ExpressPackingMonitoring.WorkstationSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择工位" Height="420" Width="720"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="app.ico"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <Style x:Key="WorkstationButtonStyle" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBlue}"/>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BorderLight}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,26">
            <TextBlock Text="请选择这台电脑的用途"
                       FontSize="28"
                       FontWeight="Black"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="按这台电脑连接的硬件选择。普通查看视频的电脑，可直接用浏览器访问监控地址。"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Style="{StaticResource WorkstationButtonStyle}" Click="CameraMonitor_Click">
                <StackPanel>
                    <Path Data="{StaticResource FluentCameraIcon}"
                          Width="56"
                          Height="56"
                          Stretch="Uniform"
                          Fill="{DynamicResource AccentBlue}"
                          HorizontalAlignment="Left"/>
                    <TextBlock Text="摄像头监控工位"
                               Margin="0,20,0,0"
                               FontSize="23"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="这台电脑接摄像头，负责实时监控、扫码录像、语音播报和接收订单。"
                               Margin="0,10,0,0"
                               FontSize="14"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Style="{StaticResource WorkstationButtonStyle}" Click="PrintStation_Click">
                <StackPanel>
                    <Path Data="{StaticResource FluentPrinterIcon}"
                          Width="56"
                          Height="56"
                          Stretch="Uniform"
                          Fill="{DynamicResource AccentOrange}"
                          HorizontalAlignment="Left"/>
                    <TextBlock Text="快递单打印工位"
                               Margin="0,20,0,0"
                               FontSize="23"
                               FontWeight="Black"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="这台电脑接打印机或使用快递助手，把订单发送到摄像头监控工位。"
                               Margin="0,10,0,0"
                               FontSize="14"
                               LineHeight="22"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
