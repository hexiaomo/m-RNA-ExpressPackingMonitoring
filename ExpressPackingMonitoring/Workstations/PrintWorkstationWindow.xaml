<Window x:Class="ExpressPackingMonitoring.PrintWorkstationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快递单打印工位" Height="560" Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Icon="app.ico"
        Background="{DynamicResource WindowBackground}"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{DynamicResource AccentBlue}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderDefault}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <Path Data="{StaticResource FluentPrinterIcon}"
                  Width="46"
                  Height="46"
                  Stretch="Uniform"
                  Fill="{DynamicResource AccentOrange}"
                  HorizontalAlignment="Left"/>
            <TextBlock Text="快递单打印工位"
                       Margin="0,14,0,0"
                       FontSize="27"
                       FontWeight="Black"
                       Foreground="{DynamicResource TextPrimary}"/>
            <TextBlock Text="连接摄像头监控工位后，快递助手订单就能发送到包装现场。"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="摄像头监控工位地址" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                <Grid Grid.Row="1" Margin="0,9,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="AddressTextBox"
                             Grid.Column="0"
                             Height="38"
                             Padding="10,0"
                             VerticalContentAlignment="Center"
                             FontSize="15"
                             Background="{DynamicResource ControlBackground}"
                             Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderStrong}"/>
                    <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Click="Reconnect_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentLinkIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="连接并记住"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{DynamicResource PanelBackground}"
                BorderBrush="{DynamicResource BorderDefault}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
            <StackPanel>
                <TextBlock x:Name="StatusTextBlock"
                           Text="正在检查上次连接..."
                           FontSize="18"
                           FontWeight="Black"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock x:Name="StatusHintTextBlock"
                           Margin="0,8,0,18"
                           Text="如果这台电脑第一次使用，请先自动查找摄像头监控工位。"
                           FontSize="13"
                           LineHeight="20"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextSecondary}"/>

                <WrapPanel>
                    <Button Style="{StaticResource SecondaryIconButtonStyle}" Click="FindMonitor_Click" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentSearchIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="自动查找"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryIconButtonStyle}" Click="OpenWeb_Click" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentVideoIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="打开视频页面"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryIconButtonStyle}" Click="InstallTool_Click" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentPrinterIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="安装快递助手联动工具"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryIconButtonStyle}" Click="TestSend_Click" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentCheckIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="测试发送订单"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryIconButtonStyle}" Click="SwitchWorkstation_Click" Margin="0,0,10,10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource FluentArrowSyncIcon}" Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Margin="0,0,7,0"/>
                            <TextBlock Text="切换工位"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Text="提示：没有安装本程序的普通电脑，也可以直接用浏览器打开摄像头监控工位显示的地址查看视频。"
                   FontSize="12"
                   Foreground="{DynamicResource TextSecondary}"/>
    </Grid>
</Window>
